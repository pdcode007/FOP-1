#include <stdio.h>

void swapWithoutPointers(int a, int b)
{
    int temp;
    temp = a;
    a = b;
    b = temp;

    printf("After swap (without pointers): a = %d, b = %d\n", a, b);
}

void swapWithPointers(int *a, int *b)
{
    int temp;
    temp = *a;
    *a = *b;
    *b = temp;
}

int main()
{
    int x = 10, y = 20;

    printf("Before swap (without pointers): x = %d, y = %d\n", x, y);
    swapWithoutPointers(x, y);

    printf("Before swap (with pointers): x = %d, y = %d\n", x, y);
    swapWithPointers(&x, &y);
    printf("After swap (with pointers): x = %d, y = %d\n", x, y);

    return 0;
}
