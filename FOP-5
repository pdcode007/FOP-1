#include <stdio.h>

void addMatrices(int r, int c)
{
    int A[10][10], B[10][10], C[10][10];

    printf("Enter Matrix A:\n");
    for(int i=0;i<r;i++)
        for(int j=0;j<c;j++)
            scanf("%d",&A[i][j]);

    printf("Enter Matrix B:\n");
    for(int i=0;i<r;i++)
        for(int j=0;j<c;j++)
            scanf("%d",&B[i][j]);

    for(int i=0;i<r;i++)
        for(int j=0;j<c;j++)
            C[i][j] = A[i][j] + B[i][j];

    printf("Result:\n");
    for(int i=0;i<r;i++)
    {
        for(int j=0;j<c;j++)
            printf("%d ",C[i][j]);
        printf("\n");
    }
}

void saddlePoint(int n)
{
    int A[10][10], i, j;

    printf("Enter matrix:\n");
    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&A[i][j]);

    int found = 0;

    for(i=0;i<n;i++)
    {
        int min = A[i][0], col = 0;

        for(j=1;j<n;j++)
        {
            if(A[i][j] < min)
            {
                min = A[i][j];
                col = j;
            }
        }

        int isSaddle = 1;
        for(int k=0;k<n;k++)
        {
            if(A[k][col] > min)
            {
                isSaddle = 0;
                break;
            }
        }

        if(isSaddle)
        {
            printf("Saddle Point = %d\n", min);
            found = 1;
        }
    }

    if(!found)
        printf("No saddle point\n");
}

void inverse2x2()
{
    int A[2][2];
    float inv[2][2];
    int det;

    printf("Enter 2x2 matrix:\n");
    for(int i=0;i<2;i++)
        for(int j=0;j<2;j++)
            scanf("%d",&A[i][j]);

    det = A[0][0]*A[1][1] - A[0][1]*A[1][0];

    if(det == 0)
    {
        printf("Inverse not possible\n");
        return;
    }

    inv[0][0] =  A[1][1] / (float)det;
    inv[0][1] = -A[0][1] / (float)det;
    inv[1][0] = -A[1][0] / (float)det;
    inv[1][1] =  A[0][0] / (float)det;

    printf("Inverse:\n");
    for(int i=0;i<2;i++)
    {
        for(int j=0;j<2;j++)
            printf("%.2f ", inv[i][j]);
        printf("\n");
    }
}

void magicSquare(int n)
{
    int A[10][10];

    printf("Enter matrix:\n");
    for(int i=0;i<n;i++)
        for(int j=0;j<n;j++)
            scanf("%d",&A[i][j]);

    int sum = 0;

    for(int j=0;j<n;j++)
        sum += A[0][j];

    int isMagic = 1;

    for(int i=1;i<n;i++)
    {
        int rowSum = 0;
        for(int j=0;j<n;j++)
            rowSum += A[i][j];

        if(rowSum != sum)
            isMagic = 0;
    }

    for(int j=0;j<n;j++)
    {
        int colSum = 0;
        for(int i=0;i<n;i++)
            colSum += A[i][j];

        if(colSum != sum)
            isMagic = 0;
    }

    int d1=0, d2=0;
    for(int i=0;i<n;i++)
    {
        d1 += A[i][i];
        d2 += A[i][n-i-1];
    }

    if(d1 != sum || d2 != sum)
        isMagic = 0;

    if(isMagic)
        printf("Magic Square\n");
    else
        printf("Not a Magic Square\n");
}

int main()
{
    int choice, r, c, n;

    do
    {
        printf("\n1. Matrix Addition\n");
        printf("2. Saddle Point\n");
        printf("3. Inverse (2x2)\n");
        printf("4. Magic Square Check\n");
        printf("5. Exit\n");

        printf("Enter choice: ");
        scanf("%d",&choice);

        switch(choice)
        {
            case 1:
                printf("Enter rows and columns: ");
                scanf("%d%d",&r,&c);
                addMatrices(r,c);
                break;

            case 2:
                printf("Enter order of square matrix: ");
                scanf("%d",&n);
                saddlePoint(n);
                break;

            case 3:
                inverse2x2();
                break;

            case 4:
                printf("Enter order of square matrix: ");
                scanf("%d",&n);
                magicSquare(n);
                break;

            case 5:
                printf("Exiting...\n");
                break;

            default:
                printf("Invalid choice\n");
        }

    } while(choice != 5);

    return 0;
}
