#include <stdio.h>
#include <string.h>

int main()
{
    int choice;
    char str[100], str2[100], sub[100], temp[100];
    int i, length, isPalindrome;

    do
    {
        printf("\nMenu:\n");
        printf("1. Length of string\n");
        printf("2. Reverse string\n");
        printf("3. Check equality of two strings\n");
        printf("4. Check palindrome\n");
        printf("5. Substring check\n");
        printf("6. Exit\n");

        printf("Enter choice: ");
        scanf("%d", &choice);

        switch(choice)
        {
            case 1:
                printf("Enter string: ");
                scanf("%s", str);
                length = strlen(str);
                printf("Length = %d\n", length);
                break;

            case 2:
                printf("Enter string: ");
                scanf("%s", str);

                length = strlen(str);
                for(i = 0; i < length; i++)
                {
                    temp[i] = str[length - i - 1];
                }
                temp[length] = '\0';

                printf("Reversed string = %s\n", temp);
                break;

            case 3:
                printf("Enter first string: ");
                scanf("%s", str);
                printf("Enter second string: ");
                scanf("%s", str2);

                if(strcmp(str, str2) == 0)
                    printf("Strings are equal\n");
                else
                    printf("Strings are not equal\n");
                break;

            case 4:
                printf("Enter string: ");
                scanf("%s", str);

                length = strlen(str);
                isPalindrome = 1;

                for(i = 0; i < length / 2; i++)
                {
                    if(str[i] != str[length - i - 1])
                    {
                        isPalindrome = 0;
                        break;
                    }
                }

                if(isPalindrome)
                    printf("Palindrome\n");
                else
                    printf("Not a palindrome\n");
                break;

            case 5:
                printf("Enter main string: ");
                scanf("%s", str);
                printf("Enter substring: ");
                scanf("%s", sub);

                if(strstr(str, sub) != NULL)
                    printf("Substring found\n");
                else
                    printf("Substring not found\n");
                break;

            case 6:
                printf("Exiting...\n");
                break;

            default:
                printf("Invalid choice\n");
        }

    } while(choice != 6);

    return 0;
}
