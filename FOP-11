#include <stdio.h>
#include<math.h>
void main()
{
    int a,i,factorial=1;
    int choice;
    do
    {
    printf("Enter choice\n");
    printf("1:Square root of a number\n");
    printf("2:Square of a number\n");
    printf("3:Cube of a number\n");
    printf("4:Check if a number is prime\n");
    printf("5:Prime factors of a number\n");
    printf("6:Factorial\n");
    printf("7:Exit\n");
    scanf("%d",&choice);
    switch(choice)
    {
        case 1:
        {
            printf("Enter Number\n");
            scanf("%d",&a);
            printf("The square root of the number is %.2f \n",sqrt(a));
            break;
        }
        case 2:
        {
            printf("Enter Number\n");
            scanf("%d",&a);
            printf("The square of the number is %.2f\n",pow(a,2));
            break;
        }
        case 3:
        {
            printf("Enter Number\n");
            scanf("%d",&a);
            printf("The square of the number is %.2f\n",pow(a,3));
            break;
        }
        case 4:
        {
            printf("Enter Number\n");
            scanf("%d",&a);
            int isPrime=1;
            
            if(a<=1)
            isPrime=0;
            
            for(i=2;i<a;i++)
            {
                if(a%i==0)
                {
                    isPrime=0;
                    break;
                }
            }
            if(isPrime)
            printf("It is a Prime Number\n");
            else
            printf("Not a Prime Number\n");
            break;
        }
        case 5:
        {
            printf("Enter Number\n");
            scanf("%d",&a);
            for(int i = 2; i <= a; i++)
            {
                while(a % i == 0)
                {
                    printf("%d ", i);
                    a = a / i;
                }
            }
            break;
        }
        case 6:
        {
            printf("Enter 1 number\n");
            scanf("%d",&a);
            for(int i=a;i>0;i--)
            factorial=factorial*i;
            printf("The factorial is %d\n",factorial);
            break;
        }
        case 7:
        {
            break;
        }
        default:
        {
        printf("INvalid choice entered");
        break;
        }
    }
    }while(choice!=7);
}
