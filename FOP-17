#include <stdio.h>
#include <math.h>

int main()
{
    int n, i;
    float x, term, sum = 0;
    int sign = 1;

    printf("Enter angle in degrees: ");
    scanf("%f", &x);

    printf("Enter number of terms: ");
    scanf("%d", &n);

    x = x * M_PI / 180;

    for(i = 1; i <= n; i++)
    {
        term = pow(x, 2*i - 1) / tgamma(2*i);
        sum += sign * term;
        sign = -sign;
    }

    printf("Sum of sine series = %.5f\n", sum);

    return 0;
}
